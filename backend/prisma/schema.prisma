generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                      String          @id @default(cuid())
  email                   String          @unique
  name                    String?
  passwordHash            String?
  role                    Role            @default(TRAVELLER)
  avatar                  String?
  image                   String?
  emailVerified           DateTime?
  phone                   String?
  isVerified              Boolean         @default(false)
  createdAt               DateTime        @default(now())
  updatedAt               DateTime        @updatedAt
  badges                  String[]        @default([])
  accounts                Account[]
  bookings                Booking[]       @relation("TravellerBookings")
  issues                  Issue[]
  notifications           Notification[]
  refundRequestsProcessed RefundRequest[] @relation("RefundProcessor")
  refundRequestsRequested RefundRequest[] @relation("RefundRequester")
  ownerProfile            OwnerProfile?
  resorts                 Resort[]        @relation("OwnerResorts")
  reviews                 Review[]
  sessions                Session[]

  @@map("users")
}

model OwnerProfile {
  id                String             @id @default(cuid())
  userId            String             @unique
  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  panNumber         String?            // Encrypted
  bankName          String?            // Encrypted
  accountNumber     String?            // Encrypted
  ifscCode          String?            // Encrypted
  gstNumber         String?            // Encrypted
  status            VerificationStatus @default(NOT_SUBMITTED)
  adminNotes        String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@map("owner_profiles")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Resort {
  id                String         @id @default(cuid())
  name              String
  slug              String         @unique
  tagline           String?
  description       String
  type              String         @default("luxury")
  location          Json
  pricePerNight     Float
  images            String[]
  amenities         String[]
  policies          Json?
  nearbyAttractions Json?
  status            ResortStatus   @default(DRAFT)
  isFeatured        Boolean        @default(false)
  isVerified        Boolean        @default(false)
  rating            Float          @default(0)
  reviewCount       Int            @default(0)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  ownerId           String
  availability      Availability[]
  bookings          Booking[]
  issues            Issue[]
  owner             User           @relation("OwnerResorts", fields: [ownerId], references: [id])
  reviews           Review[]
  roomTypes         RoomType[]

  @@map("resorts")
}

model RoomType {
  id             String   @id @default(cuid())
  name           String
  description    String
  pricePerNight  Float
  capacity       Int
  amenities      String[]
  images         String[]
  availableCount Int      @default(1)
  resortId       String
  resort         Resort   @relation(fields: [resortId], references: [id], onDelete: Cascade)

  @@map("room_types")
}

model Booking {
  id               String          @id @default(cuid())
  checkIn          DateTime
  checkOut         DateTime
  guests           Int
  nights           Int
  pricePerNight    Float
  subtotal         Float
  commissionRate   Float
  commissionAmount Float
  ownerEarnings    Float
  totalPrice       Float
  status           BookingStatus   @default(PENDING)
  specialRequests  String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  travellerId      String
  resortId         String
  resort           Resort          @relation(fields: [resortId], references: [id])
  traveller        User            @relation("TravellerBookings", fields: [travellerId], references: [id])
  issues           Issue[]
  payment          Payment?
  refundRequests   RefundRequest[]
  review           Review?

  @@map("bookings")
}

model Payment {
  id                String        @id @default(cuid())
  amount            Float
  currency          String        @default("INR")
  status            PaymentStatus @default(PENDING)
  paidAt            DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  bookingId         String        @unique
  payoutAmount      Float?
  payoutDate        DateTime?
  payoutReference   String?
  payoutStatus      PayoutStatus  @default(PENDING_MANUAL)
  provider          String        @default("cashfree")
  providerCreatedAt DateTime?
  providerOrderId   String?       @unique
  providerPayload   Json?
  providerPaymentId String?       @unique
  providerStatus    String?
  booking           Booking       @relation(fields: [bookingId], references: [id])

  @@map("payments")
}

model RefundRequest {
  id              String       @id @default(cuid())
  bookingId       String
  amount          Float
  requesterId     String
  reason          String?
  status          RefundStatus @default(PENDING)
  processedBy     String?
  payoutReference String?
  notes           String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  booking         Booking      @relation(fields: [bookingId], references: [id])
  processedByUser User?        @relation("RefundProcessor", fields: [processedBy], references: [id])
  requester       User         @relation("RefundRequester", fields: [requesterId], references: [id])

  @@map("refund_requests")
}

model Review {
  id        String   @id @default(cuid())
  rating    Int
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  userId    String
  resortId  String
  bookingId String   @unique
  booking   Booking  @relation(fields: [bookingId], references: [id])
  resort    Resort   @relation(fields: [resortId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@map("reviews")
}

model Availability {
  id        String   @id @default(cuid())
  date      DateTime @db.Date
  isBlocked Boolean  @default(false)
  reason    String?
  createdAt DateTime @default(now())
  resortId  String
  resort    Resort   @relation(fields: [resortId], references: [id])

  @@unique([resortId, date])
  @@map("availability")
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType @default(INFO)
  title     String
  message   String
  link      String?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model Issue {
  id          String      @id @default(cuid())
  userId      String
  resortId    String?
  bookingId   String?
  title       String
  description String
  status      IssueStatus @default(OPEN)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  booking     Booking?    @relation(fields: [bookingId], references: [id])
  resort      Resort?     @relation(fields: [resortId], references: [id])
  user        User        @relation(fields: [userId], references: [id])

  @@map("issues")
}

enum Role {
  TRAVELLER
  RESORT_OWNER
  SUPER_ADMIN
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  CAPTURED
  FAILED
  REFUNDED
}

enum RefundStatus {
  PENDING
  APPROVED
  DECLINED
  PROCESSED
}

enum PayoutStatus {
  PENDING_MANUAL
  SENT
  FAILED
}

enum ResortStatus {
  DRAFT
  ACTIVE
  SUSPENDED
}

enum NotificationType {
  INFO
  SUCCESS
  WARNING
  ERROR
  BOOKING
  PAYMENT
  SYSTEM
}

enum IssueStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum VerificationStatus {
  NOT_SUBMITTED
  PENDING
  VERIFIED
  REJECTED
}
